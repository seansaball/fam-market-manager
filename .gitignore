# Python
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
dist/
build/
*.egg

# Virtual environments
venv/
.venv/
env/
build_venv/

# Database (local data — never commit)
*.db
*.db.bak
*.bak
*.sqlite
*.sqlite3
backups/

# IDE / Editor
.vscode/
.idea/
*.swp
*.swo
*~

# OS files
.DS_Store
Thumbs.db
desktop.ini

# Claude Code session data
.claude/

# PyInstaller
*.manifest
*.spec.bak

# Exports / generated files
*.csv
*.png
*.pdf
*.docx

# Release binaries (use GitHub Releases instead)
releases/
*.zip

# Log files
*.log

# Runtime artifacts (ledger backups, pytest)
fam_ledger_backup*.txt
fam_*_ledger_backup*.txt
.pytest_cache/

# Photos (local runtime data — synced to Google Drive, not git)
photos/

# Google Sheets sync credentials (NEVER commit)
*credentials*.json
*service_account*.json
