# Python
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
dist/
build/
*.egg

# Virtual environments
venv/
.venv/
env/
build_venv/

# Database (local data — never commit)
*.db
*.db-shm
*.db-wal
*.db.bak
*.bak
*.sqlite
*.sqlite3
backups/

# IDE / Editor
.vscode/
.idea/
*.swp
*.swo
*~

# OS files
.DS_Store
Thumbs.db
desktop.ini

# Claude Code session data
.claude/

# PyInstaller
*.manifest
*.spec.bak

# Exports / generated files
*.csv
*.png
*.pdf
*.docx

# Release binaries (use GitHub Releases instead)
releases/
*.zip

# Release-notes HTML (board/email distribution only — not for repo or release page)
FAM_Manager_v*_Release_Notes.html

# Log files
*.log

# Runtime artifacts (ledger backups, pytest, local locks/scripts)
fam_ledger_backup*.txt
fam_*_ledger_backup*.txt
.pytest_cache/
.fam_instance.lock
_fam_update.bat

# Photos (local runtime data — synced to Google Drive, not git)
photos/

# Google Sheets sync credentials (NEVER commit)
*credentials*.json
*service_account*.json
